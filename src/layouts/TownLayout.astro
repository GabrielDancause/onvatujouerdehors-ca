---
import BaseHead from './BaseHead.astro';
const { page } = Astro.props;
---
<html lang="fr">
<head>
    <BaseHead title={page.title} description={page.description} ogTitle={page.ogTitle} ogDescription={page.ogDescription} />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #fafafa; color: #1a1a1a; line-height: 1.7; }
        .back-link { position: absolute; top: 18px; left: 24px; z-index: 10; }
        .back-link a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.82rem; font-weight: 500; transition: color 0.15s; }
        .back-link a:hover { color: #fff; }
        .hero { color: #fff; padding: 80px 24px 64px; text-align: center; position: relative; }
        .hero .badge { display: inline-block; background: rgba(255,255,255,0.15); padding: 6px 16px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.5px; margin-bottom: 16px; text-transform: uppercase; }
        .hero h1 { font-size: 2.8rem; font-weight: 700; margin-bottom: 12px; line-height: 1.1; }
        .hero .tagline { font-size: 1.15rem; opacity: 0.85; max-width: 560px; margin: 0 auto 12px; font-style: italic; }
        .hero .sub { font-size: 0.88rem; opacity: 0.6; }
        .container { max-width: 740px; margin: 0 auto; padding: 44px 20px 60px; }
        .stats-bar { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 44px; }
        .stat { background: #fff; border-radius: 12px; padding: 22px 16px; text-align: center; border: 1px solid rgba(0,0,0,0.04); box-shadow: 0 1px 4px rgba(0,0,0,0.04); }
        .stat .icon { font-size: 1.5rem; margin-bottom: 6px; }
        .stat .label { font-size: 0.72rem; color: #888; text-transform: uppercase; letter-spacing: 0.3px; }
        .stat .value { font-size: 0.92rem; font-weight: 600; color: #2D5016; }
        .section { margin-bottom: 44px; }
        .section h2 { font-size: 1.5rem; font-weight: 700; color: #2D5016; margin-bottom: 16px; }
        .section p { font-size: 0.94rem; color: #555; line-height: 1.8; margin-bottom: 14px; }
        .card-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; margin-top: 16px; }
        .card { background: #fff; border-radius: 12px; padding: 22px 18px; border: 1px solid rgba(0,0,0,0.04); box-shadow: 0 1px 4px rgba(0,0,0,0.04); }
        .card .c-icon { font-size: 1.3rem; margin-bottom: 8px; }
        .card h3 { font-size: 1rem; font-weight: 600; color: #2D5016; margin-bottom: 6px; }
        .card p { font-size: 0.84rem; color: #777; line-height: 1.6; margin: 0; }
        .card-link { text-decoration: none; color: inherit; transition: transform 0.15s, box-shadow 0.15s; display: block; }
        .card-link:hover { transform: translateY(-2px); }
        .card-link:hover .card { box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
        .poi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-top: 16px; }
        .poi { background: #fff; border-radius: 12px; padding: 18px 14px; text-align: center; border: 1px solid rgba(0,0,0,0.04); box-shadow: 0 1px 4px rgba(0,0,0,0.04); text-decoration: none; color: #2D5016; transition: transform 0.15s, box-shadow 0.15s; display: block; }
        .poi:hover { transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
        .poi .p-icon { font-size: 1.4rem; margin-bottom: 6px; }
        .poi .p-name { font-size: 0.84rem; font-weight: 600; }
        .poi .p-type { font-size: 0.72rem; color: #999; margin-top: 2px; }
        .timeline { margin-top: 16px; }
        .timeline-item { position: relative; padding-left: 28px; margin-bottom: 18px; }
        .timeline-item::before { content: ''; position: absolute; left: 6px; top: 8px; width: 10px; height: 10px; background: #2D5016; border-radius: 50%; }
        .timeline-item::after { content: ''; position: absolute; left: 10px; top: 22px; width: 2px; height: calc(100% + 4px); background: #e0e0e0; }
        .timeline-item:last-child::after { display: none; }
        .timeline-item .year { font-size: 0.82rem; font-weight: 700; color: #2D5016; }
        .timeline-item .desc { font-size: 0.84rem; color: #777; line-height: 1.5; }
        .info-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; margin-top: 16px; }
        .info-card { background: #fff; border-radius: 12px; padding: 20px 18px; border: 1px solid rgba(0,0,0,0.04); box-shadow: 0 1px 4px rgba(0,0,0,0.04); }
        .info-card h3 { font-size: 0.85rem; font-weight: 600; color: #2D5016; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.3px; }
        .info-card p { font-size: 0.88rem; color: #555; line-height: 1.6; margin: 0; }
        .info-card a { color: #2D5016; font-weight: 600; }
        .cta-banner { background: #2D5016; border-radius: 14px; padding: 36px 28px; text-align: center; margin-top: 44px; }
        .cta-banner h2 { color: #FAF8EB; font-size: 1.4rem; margin-bottom: 10px; }
        .cta-banner p { color: rgba(250,248,235,0.7); font-size: 0.9rem; margin-bottom: 20px; }
        .cta-banner a { display: inline-block; background: #FAF8EB; color: #2D5016; padding: 12px 28px; border-radius: 8px; font-size: 0.9rem; font-weight: 600; text-decoration: none; transition: transform 0.15s; margin: 0 6px; }
        .cta-banner a:hover { transform: translateY(-2px); }
        .footer { text-align: center; padding: 40px 24px; font-size: 0.82rem; color: #aaa; border-top: 1px solid #eee; }
        .footer a { color: #2D5016; text-decoration: none; }
        @media (max-width: 600px) {
            .hero { padding: 60px 18px 48px; }
            .hero h1 { font-size: 2.2rem; }
            .stats-bar { grid-template-columns: repeat(2, 1fr); }
            .card-grid, .info-grid { grid-template-columns: 1fr; }
            .poi-grid { grid-template-columns: repeat(2, 1fr); }
            .container { padding: 28px 16px 48px; }
            .back-link { top: 12px; left: 16px; }
        }
    </style>
</head>
<body>

<div class="hero" style={`background: ${page.heroGradient};`}>
    {page.backLink && <div class="back-link"><a href={page.backLink.href}>{page.backLink.text}</a></div>}
    {page.badge && <div class="badge">{page.badge}</div>}
    <h1 set:html={page.h1} />
    {page.tagline && <p class="tagline">{page.tagline}</p>}
    {page.heroSub && <p class="sub">{page.heroSub}</p>}
</div>

<div class="container">

    {page.stats && page.stats.length > 0 && (
        <div class="stats-bar">
            {page.stats.map((s: any) => (
                <div class="stat">
                    <div class="icon">{s.icon}</div>
                    <div class="value">{s.value}</div>
                    <div class="label">{s.label}</div>
                </div>
            ))}
        </div>
    )}

    {page.sections?.map((section: any) => (
        <div class="section">
            <h2>{section.title}</h2>

            {section.paragraphs?.map((p: string) => (
                <p set:html={p} />
            ))}

            {section.cards && (
                <div class="card-grid">
                    {section.cards.map((c: any) => (
                        c.href ? (
                            <a href={c.href} class="card-link">
                                <div class="card">
                                    <div class="c-icon">{c.icon}</div>
                                    <h3>{c.title}</h3>
                                    <p set:html={c.description} />
                                </div>
                            </a>
                        ) : (
                            <div class="card">
                                <div class="c-icon">{c.icon}</div>
                                <h3>{c.title}</h3>
                                <p set:html={c.description} />
                            </div>
                        )
                    ))}
                </div>
            )}

            {section.pois && (
                <div class="poi-grid">
                    {section.pois.map((p: any) => (
                        p.href ? (
                            <a href={p.href} class="poi">
                                <div class="p-icon">{p.icon}</div>
                                <div class="p-name">{p.name}</div>
                                <div class="p-type">{p.type}</div>
                            </a>
                        ) : (
                            <div class="poi">
                                <div class="p-icon">{p.icon}</div>
                                <div class="p-name">{p.name}</div>
                                <div class="p-type">{p.type}</div>
                            </div>
                        )
                    ))}
                </div>
            )}

            {section.timeline && (
                <div class="timeline">
                    {section.timeline.map((t: any) => (
                        <div class="timeline-item">
                            <div class="year">{t.year}</div>
                            <div class="desc" set:html={t.desc} />
                        </div>
                    ))}
                </div>
            )}

            {section.infoCards && (
                <div class="info-grid">
                    {section.infoCards.map((ic: any) => (
                        <div class="info-card">
                            <h3>{ic.title}</h3>
                            <p set:html={ic.content} />
                        </div>
                    ))}
                </div>
            )}
        </div>
    ))}

    {page.ctaBanner && (
        <div class="cta-banner">
            <h2>{page.ctaBanner.title}</h2>
            <p>{page.ctaBanner.text}</p>
            {page.ctaBanner.links.map((l: any) => (
                <a href={l.href}>{l.text}</a>
            ))}
        </div>
    )}

</div>

{page.footer && (
    <div class="footer">
        <p set:html={page.footer} />
    </div>
)}

</body>
</html>
